{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "module": "ESNext",
    "target": "ES2020",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "types": ["node"],
    "paths": {
      "@shared/*": ["../shared-data/src/*"]
    }
  },
  "include": ["src/**/*"]
}
